# === BASE DE DONNÉES MYSQL ===
DATABASE_URL="mysql://user:password@host:3306/plawimadd_group"
DB_HOST="127.0.0.1"
DB_USER="root"
DB_PASSWORD=
DB_NAME="plawimadd_group"

# === NEXTAUTH (AUTHENTIFICATION) ===
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-to-a-random-64-char-hex-string"
JWT_SECRET="change-me-to-another-random-64-char-hex-string"

# === GOOGLE OAUTH ===
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# === KKIAPAY (Paiement Mobile) ===
NEXT_PUBLIC_KKIAPAY_PUBLIC_API_KEY="your-kkiapay-public-key"
KKIAPAY_PUBLIC_API_KEY="your-kkiapay-public-key"
KKIAPAY_PRIVATE_API_KEY="your-kkiapay-private-key"
KKIAPAY_SECRET="your-kkiapay-secret"
# Hash secret du webhook. Ce n'est PAS une valeur fournie par Kkiapay : vous la
# choisissez vous-meme et la saisissez dans le champ "Hash Secret" du tableau de
# bord (Developpeurs > Cles API > Webhook > Ajouter un webhook). La meme valeur
# doit figurer ici. Kkiapay la renvoie ensuite dans l'en-tete x-kkiapay-secret.
# Distinct de KKIAPAY_SECRET. Sans lui, le webhook refuse tous les appels et le
# filet de securite des paiements est inoperant.
# Generer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KKIAPAY_WEBHOOK_SECRET="your-self-chosen-webhook-hash-secret"

# === EMAIL (Nodemailer) ===
EMAIL_USER="your-email@gmail.com"
EMAIL_PASS="your-app-password"
CONTACT_RECEIVER_EMAIL="contact@example.com"

# === CLOUDINARY (Images) ===
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# === PARAMÈTRES GLOBAUX DU SITE ===
NEXT_PUBLIC_CURRENCY="CFA"
NEXT_PUBLIC_SITE_NAME="Plawimadd Group"
NEXT_PUBLIC_SITE_DESCRIPTION="Plawimadd Group - Votre boutique en ligne de produits électronique"
NEXT_PUBLIC_SITE_LOGO="/logo.png"
NEXT_PUBLIC_SITE_FAVICON="/favicon.ico"
